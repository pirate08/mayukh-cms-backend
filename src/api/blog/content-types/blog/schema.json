{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "minLength": 5,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "blocks",
      "required": true
    },
    "tag": {
      "type": "enumeration",
      "required": true,
      "default": "Web Development",
      "enum": [
        "Web Development",
        "Architecture",
        "Lessons Learned",
        "Database"
      ]
    },
    "articleTags": {
      "type": "json",
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "isFeatured": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "authorName": {
      "type": "string",
      "default": "Mayukh Deb Goswami",
      "required": true
    }
  }
}
